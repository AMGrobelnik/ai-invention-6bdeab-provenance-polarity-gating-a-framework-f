\@writefile{toc}{\contentsline {section}{\numberline {1}Introduction}{1}{section.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The Provenance-Polarity Gate (PPG) pipeline. An LLM translator extracts premises and declares a provenance class (A=document-extensional, B=world-knowledge-universal, C=document-stipulated). The three-axis endorsement battery measures each premise's invariance fingerprint across document-presence, entity-renaming, and query-counterfactual interventions. The gate admits a premise only when its measured fingerprint matches the polarity required by its declared class. Admitted premises feed a SWI-Prolog backward chainer that emits a human-auditable trace-graph.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:pipeline}{{1}{2}{The Provenance-Polarity Gate (PPG) pipeline. An LLM translator extracts premises and declares a provenance class (A=document-extensional, B=world-knowledge-universal, C=document-stipulated). The three-axis endorsement battery measures each premise's invariance fingerprint across document-presence, entity-renaming, and query-counterfactual interventions. The gate admits a premise only when its measured fingerprint matches the polarity required by its declared class. Admitted premises feed a SWI-Prolog backward chainer that emits a human-auditable trace-graph}{figure.1}{}}
